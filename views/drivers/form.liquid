{% layout "layouts/main" %}

{% block conteudo %}
<div class="mx-auto max-w-xl">
  <h1 class="mb-4 text-2xl font-semibold text-slate-900">{{ titulo }}</h1>

  {% if erro == "campos" %}
  <div class="mb-4 rounded border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
    Preencha nome, e-mail e uma senha com pelo menos 6 caracteres.
  </div>
  {% elsif erro == "email" %}
  <div class="mb-4 rounded border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
    Já existe um usuário com esse e-mail.
  </div>
  {% endif %}

  <form
    method="post"
    action="{{ action }}"
    class="space-y-4 rounded-lg bg-white p-6 shadow-sm"
  >
    <div>
      <label for="nome" class="block text-sm font-medium text-slate-700">
        Nome
      </label>
      <input
        id="nome"
        name="nome"
        type="text"
        required
        value="{{ entregador.nome }}"
        class="mt-1 block w-full rounded border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-slate-700">
        E-mail
      </label>
      <input
        id="email"
        name="email"
        type="email"
        required
        value="{{ entregador.email }}"
        class="mt-1 block w-full rounded border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none"
      />
    </div>
    {% if mostrarSenha %}
    <div>
      <label for="senha" class="block text-sm font-medium text-slate-700">
        Senha
      </label>
      <input
        id="senha"
        name="senha"
        type="password"
        required
        minlength="6"
        class="mt-1 block w-full rounded border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none"
      />
      <p class="mt-1 text-xs text-slate-500">Mínimo 6 caracteres.</p>
    </div>
    {% endif %}
    <div class="flex items-center justify-end gap-2">
      <a
        href="/entregadores"
        class="rounded border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-100"
      >
        Cancelar
      </a>
      <button
        type="submit"
        class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800"
      >
        Salvar
      </button>
    </div>
  </form>
</div>
{% endblock %}
