{% layout "layouts/main" %}

{% block conteudo %}
<div class="mb-4 flex items-center justify-between">
  <h1 class="text-2xl font-semibold text-slate-900">Entregadores</h1>
  <a
    href="/entregadores/novo"
    class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800"
  >
    + Novo entregador
  </a>
</div>

{% if criado %}
<div class="mb-4 rounded border border-green-200 bg-green-50 px-3 py-2 text-sm text-green-700">
  Entregador cadastrado com sucesso.
</div>
{% elsif atualizado %}
<div class="mb-4 rounded border border-green-200 bg-green-50 px-3 py-2 text-sm text-green-700">
  Entregador atualizado com sucesso.
</div>
{% endif %}

<div class="overflow-hidden rounded-lg bg-white shadow-sm">
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-50 text-slate-600">
      <tr>
        <th class="px-4 py-2 text-left font-medium">Nome</th>
        <th class="px-4 py-2 text-left font-medium">E-mail</th>
        <th class="px-4 py-2 text-left font-medium">Situação</th>
        <th class="px-4 py-2 text-right font-medium">Ações</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      {% for entregador in entregadores %}
      <tr>
        <td class="px-4 py-3 text-slate-900">{{ entregador.nome }}</td>
        <td class="px-4 py-3 text-slate-600">{{ entregador.email }}</td>
        <td class="px-4 py-3">
          {% if entregador.ativo %}
          <span class="inline-flex rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">
            Ativo
          </span>
          {% else %}
          <span class="inline-flex rounded-full bg-slate-200 px-2 py-0.5 text-xs font-medium text-slate-700">
            Inativo
          </span>
          {% endif %}
        </td>
        <td class="px-4 py-3 text-right">
          <div class="inline-flex items-center gap-2">
            <a
              href="/entregadores/{{ entregador.id }}/editar"
              class="rounded border border-slate-300 px-3 py-1 text-xs text-slate-700 hover:bg-slate-100"
            >
              Editar
            </a>
            <form method="post" action="/entregadores/{{ entregador.id }}/desativar">
              <button
                type="submit"
                class="rounded border border-slate-300 px-3 py-1 text-xs text-slate-700 hover:bg-slate-100"
              >
                {% if entregador.ativo %}Desativar{% else %}Ativar{% endif %}
              </button>
            </form>
          </div>
        </td>
      </tr>
      {% else %}
      <tr>
        <td colspan="4" class="px-4 py-6 text-center text-slate-500">
          Nenhum entregador cadastrado.
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
