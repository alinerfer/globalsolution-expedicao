{% layout "layouts/main" %}

{% block conteudo %}
<div class="mx-auto max-w-md">
  <div class="rounded-lg bg-white p-6 shadow-sm">
    <h1 class="text-xl font-semibold text-slate-900">Entrar</h1>
    <p class="mt-1 text-sm text-slate-500">
      Acesse com sua conta de operador.
    </p>

    {% if erro %}
    <div class="mt-4 rounded border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
      E-mail ou senha inválidos.
    </div>
    {% endif %}

    <form method="post" action="/login" class="mt-5 space-y-4">
      <div>
        <label for="email" class="block text-sm font-medium text-slate-700">
          E-mail
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="mt-1 block w-full rounded border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none"
        />
      </div>
      <div>
        <label for="senha" class="block text-sm font-medium text-slate-700">
          Senha
        </label>
        <input
          id="senha"
          name="senha"
          type="password"
          required
          autocomplete="current-password"
          class="mt-1 block w-full rounded border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none"
        />
      </div>
      <button
        type="submit"
        class="w-full rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800"
      >
        Entrar
      </button>
    </form>
  </div>
</div>
{% endblock %}
