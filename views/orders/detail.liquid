{% layout "layouts/main" %}

{% block conteudo %}
<div class="mb-4 flex items-center justify-between">
  <div>
    <a href="/pedidos" class="text-sm text-slate-500 hover:underline">← Voltar</a>
    <h1 class="mt-1 text-2xl font-semibold text-slate-900">
      Pedido #{{ pedido.id }}
    </h1>
  </div>
  <span
    class="inline-flex items-center rounded-full bg-slate-200 px-3 py-1 text-sm font-medium text-slate-800"
  >
    {{ statusLabel }}
  </span>
</div>

{% if podePreparar or podeMarcarPronto or podeCancelar %}
<div class="mb-4 flex flex-wrap items-center gap-2">
  {% if podePreparar %}
  <form method="post" action="/pedidos/{{ pedido.id }}/preparar">
    <button
      type="submit"
      class="rounded bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700"
    >
      Iniciar preparo
    </button>
  </form>
  {% endif %}
  {% if podeMarcarPronto %}
  <form method="post" action="/pedidos/{{ pedido.id }}/pronto">
    <button
      type="submit"
      class="rounded bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700"
    >
      Marcar como pronto
    </button>
  </form>
  {% endif %}
  {% if podeCancelar %}
  <form
    method="post"
    action="/pedidos/{{ pedido.id }}/cancelar"
    onsubmit="return confirm('Cancelar este pedido?');"
  >
    <button
      type="submit"
      class="rounded border border-red-300 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-50"
    >
      Cancelar pedido
    </button>
  </form>
  {% endif %}
</div>
{% endif %}

<div class="grid gap-4 lg:grid-cols-3">
  <section class="rounded-lg bg-white p-6 shadow-sm lg:col-span-2">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-600">
      Itens
    </h2>
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="text-slate-600">
        <tr>
          <th class="py-2 text-left font-medium">Item</th>
          <th class="py-2 text-right font-medium">Qtd</th>
          <th class="py-2 text-right font-medium">Unitário</th>
          <th class="py-2 text-right font-medium">Subtotal</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {% for item in pedido.itens %}
        <tr>
          <td class="py-2 text-slate-900">{{ item.nome }}</td>
          <td class="py-2 text-right text-slate-700">{{ item.quantidade }}</td>
          <td class="py-2 text-right text-slate-700">
            R$ {{ item.precoUnitario | round: 2 }}
          </td>
          <td class="py-2 text-right text-slate-900">
            R$ {{ item.quantidade | times: item.precoUnitario | round: 2 }}
          </td>
        </tr>
        {% endfor %}
      </tbody>
      <tfoot>
        <tr class="border-t border-slate-200">
          <td colspan="3" class="py-2 text-right font-medium text-slate-700">
            Total
          </td>
          <td class="py-2 text-right text-lg font-semibold text-slate-900">
            R$ {{ pedido.valorTotal | round: 2 }}
          </td>
        </tr>
      </tfoot>
    </table>

    {% if pedido.observacoes %}
    <div class="mt-4 rounded border border-slate-200 bg-slate-50 p-3 text-sm">
      <div class="mb-1 text-xs font-semibold uppercase text-slate-500">
        Observações
      </div>
      {{ pedido.observacoes }}
    </div>
    {% endif %}
  </section>

  {% if mostraMapa %}
  <section class="rounded-lg bg-white p-4 shadow-sm lg:col-span-2">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-600">
      Mapa
    </h2>
    <div
      id="mapa"
      class="h-72 w-full rounded border border-slate-200"
      data-pedido-id="{{ pedido.id }}"
      data-acompanha="{% if acompanhaEntregador %}1{% else %}0{% endif %}"
      data-tem-destino="{% if temDestino %}1{% else %}0{% endif %}"
      data-destino-lat="{{ pedido.latitude }}"
      data-destino-lng="{{ pedido.longitude }}"
    ></div>
    {% if acompanhaEntregador %}
    <p id="ultimaAtualizacao" class="mt-2 text-xs text-slate-500">
      Aguardando primeira posição do entregador...
    </p>
    {% endif %}
  </section>
  {% endif %}

  <aside class="space-y-4">
    <section class="rounded-lg bg-white p-6 shadow-sm">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-600">
        Cliente
      </h2>
      <p class="font-medium text-slate-900">{{ pedido.clienteNome }}</p>
      <p class="text-sm text-slate-600">{{ pedido.clienteTelefone }}</p>
      <p class="mt-3 text-sm text-slate-700">{{ pedido.enderecoEntrega }}</p>
      {% if pedido.latitude and pedido.longitude %}
      <p class="mt-1 text-xs text-slate-500">
        {{ pedido.latitude }}, {{ pedido.longitude }}
      </p>
      {% endif %}
    </section>

    <section class="rounded-lg bg-white p-6 shadow-sm">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-600">
        Entregador
      </h2>
      {% if pedido.entregador %}
      <p class="font-medium text-slate-900">{{ pedido.entregador.nome }}</p>
      <p class="text-sm text-slate-600">{{ pedido.entregador.email }}</p>
      {% else %}
      <p class="text-sm text-slate-500">Nenhum entregador atribuído.</p>
      {% endif %}

      {% if podeAtribuir %}
      {% if erro == "entregador" %}
      <div class="mt-3 rounded border border-red-200 bg-red-50 px-3 py-2 text-xs text-red-700">
        Selecione um entregador ativo.
      </div>
      {% endif %}
      <form method="post" action="/pedidos/{{ pedido.id }}/atribuir" class="mt-4 space-y-2">
        <label for="entregadorId" class="block text-xs font-medium text-slate-700">
          Atribuir a
        </label>
        <select
          id="entregadorId"
          name="entregadorId"
          required
          class="block w-full rounded border border-slate-300 px-2 py-1 text-sm"
        >
          <option value="">Selecione...</option>
          {% for e in entregadores %}
          <option value="{{ e.id }}">{{ e.nome }}</option>
          {% endfor %}
        </select>
        <button
          type="submit"
          class="w-full rounded bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-800"
        >
          Atribuir e despachar
        </button>
        {% if entregadores.size == 0 %}
        <p class="text-xs text-slate-500">
          Cadastre um entregador ativo em
          <a href="/entregadores" class="underline">Entregadores</a>.
        </p>
        {% endif %}
      </form>
      {% endif %}
    </section>
  </aside>
</div>

{% if mostraMapa %}
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>
<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>
<script>
  (function () {
    const div = document.getElementById('mapa');
    const pedidoId = div.dataset.pedidoId;
    const acompanha = div.dataset.acompanha === '1';
    const temDestino = div.dataset.temDestino === '1';
    const destinoLat = parseFloat(div.dataset.destinoLat);
    const destinoLng = parseFloat(div.dataset.destinoLng);

    const centroInicial = temDestino
      ? [destinoLat, destinoLng]
      : [-23.55, -46.63];
    const mapa = L.map('mapa').setView(centroInicial, temDestino ? 14 : 11);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '© OpenStreetMap',
    }).addTo(mapa);

    if (temDestino) {
      L.marker([destinoLat, destinoLng])
        .addTo(mapa)
        .bindPopup('Destino');
    }

    if (!acompanha) {
      return;
    }

    const elInfo = document.getElementById('ultimaAtualizacao');
    let markerEntregador = null;

    async function atualizar() {
      try {
        const resp = await fetch('/pedidos/' + pedidoId + '/localizacao');
        if (!resp.ok) return;
        const dados = await resp.json();
        if (!dados.temPosicao) return;

        const ponto = [dados.latitude, dados.longitude];
        if (markerEntregador) {
          markerEntregador.setLatLng(ponto);
        } else {
          markerEntregador = L.marker(ponto)
            .addTo(mapa)
            .bindPopup('Entregador');
          if (!temDestino) {
            mapa.setView(ponto, 14);
          }
        }
        if (elInfo) {
          const data = new Date(dados.recordedAt);
          elInfo.textContent =
            'Última posição: ' + data.toLocaleTimeString('pt-BR');
        }
      } catch (e) {
        console.error(e);
      }
    }

    atualizar();
    setInterval(atualizar, 5000);
  })();
</script>
{% endif %}
{% endblock %}
