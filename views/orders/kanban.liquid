{% layout "layouts/main" %}

{% block conteudo %}
<div class="mb-4 flex items-center justify-between">
  <h1 class="text-2xl font-semibold text-slate-900">Pedidos</h1>
  <a
    href="/pedidos/novo"
    class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800"
  >
    + Novo pedido
  </a>
</div>

<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
  {% for coluna in colunas %}
  <div class="rounded-lg bg-white p-3 shadow-sm">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-600">
        {{ coluna.label }}
      </h2>
      <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-700">
        {{ coluna.pedidos.size }}
      </span>
    </div>
    <div class="space-y-2">
      {% for pedido in coluna.pedidos %}
      <a
        href="/pedidos/{{ pedido.id }}"
        class="block rounded border border-slate-200 bg-slate-50 p-3 hover:border-slate-400 hover:bg-white"
      >
        <div class="flex items-center justify-between text-xs text-slate-500">
          <span>#{{ pedido.id }}</span>
          <span>R$ {{ pedido.valorTotal | round: 2 }}</span>
        </div>
        <div class="mt-1 font-medium text-slate-900">
          {{ pedido.clienteNome }}
        </div>
        {% if pedido.entregador %}
        <div class="mt-1 text-xs text-slate-500">
          Entregador: {{ pedido.entregador.nome }}
        </div>
        {% endif %}
      </a>
      {% else %}
      <div class="rounded border border-dashed border-slate-200 px-3 py-4 text-center text-xs text-slate-400">
        Sem pedidos
      </div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}
</div>
{% endblock %}
